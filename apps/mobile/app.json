{
  "expo": {
    "name": "Calouch",
    "slug": "calouch",
    "scheme": "calouch",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "primaryColor": "#84CC16",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.calouch.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Calouch, ilerleme fotoğrafı çekmek için kameraya erişir.",
        "NSPhotoLibraryUsageDescription": "Calouch, ilerleme fotoğrafı seçmek için galerine erişir.",
        "NSFaceIDUsageDescription": "Calouch, ilerleme fotoğraflarını Face ID ile koruyabilir."
      }
    },
    "android": {
      "package": "com.calouch.app",
      "adaptiveIcon": {
        "backgroundColor": "#84CC16",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Calouch, ilerleme fotoğrafı seçmek için galerine erişir.",
          "cameraPermission": "Calouch, ilerleme fotoğrafı çekmek için kameraya erişir."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Calouch, ilerleme fotoğraflarını Face ID ile koruyabilir."
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Calouch, Bugün ekranında bugünkü adım ve aktif enerji verilerini göstermek için Health verilerini okur.",
          "NSHealthUpdateUsageDescription": false,
          "background": false
        }
      ],
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18bf0243-9473-4144-b75c-b6861faacda3"
      }
    },
    "owner": "akintkaya"
  }
}
