# Continuous Native Generation — android/ ve ios/ prebuild ile üretilir.
# Bir native klasör commit edilecekse (§01 native entegrasyon kapısı) bu karar
# 14-open-decisions.md'ye yazılır ve buradan çıkarılır.
apps/mobile/android/
apps/mobile/ios/

# Native credentials — asla commit edilmez
*.keystore
*.jks
*.p8
*.p12
*.mobileprovision
*.cer
google-services.json
GoogleService-Info.plist

# Env — §01: secret istemci/public ayrımı
.env
.env.*
!.env.example

